# Copy to .env and fill in.
# STT runs LOCALLY (offline Whisper) and needs no key.
# LLM + TTS use OpenAI; without a key they fall back to deterministic stubs.
OPENAI_API_KEY=sk-...

# --- Offline Whisper STT (local) ---
WHISPER_MODEL=base          # tiny | base | small | medium | large-v3
WHISPER_DEVICE=cpu          # cpu | cuda
WHISPER_COMPUTE_TYPE=int8   # int8 (cpu) | float16 (gpu)
WHISPER_BEAM_SIZE=1
WHISPER_LANGUAGE=en         # force English; empty = auto-detect (multilingual)
PRELOAD_STT=true            # load model at startup so the site goes live only when ready

# --- OpenAI (LLM + TTS) ---
LLM_MODEL=gpt-4o-mini
TTS_MODEL=tts-1
TTS_VOICE=alloy

# Stub ALL providers (skips the Whisper model load) — handy for CI/demos
MOCK_MODE=false

# Database (SQLite by default; Postgres example below)
DATABASE_URL=sqlite:///./banking.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/banking
